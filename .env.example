# ---- Kaiten upstream ----
# Full Kaiten domain, without https:// and without any path
KAITEN_HOST=mycompany.kaiten.ru
# API token from Kaiten profile > Settings > API keys
KAITEN_TOKEN=

# ---- OAuth 2.1 (required in production) ----
# Any string (also entered manually in Claude's connector UI > Advanced settings)
OAUTH_CLIENT_ID=kaiten-claude
# Generate with: openssl rand -hex 32
OAUTH_CLIENT_SECRET=
# Password typed on the consent page to approve each OAuth flow
# Generate with: openssl rand -base64 24
OWNER_PASSWORD=
# Comma-separated whitelist of allowed OAuth redirect URIs
OAUTH_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback

# ---- Hardening (optional, recommended) ----
# Public hostname used to build metadata URLs — prevents Host header injection.
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically; Render sets RENDER_EXTERNAL_HOSTNAME.
# Override here if your platform doesn't.
# PUBLIC_HOSTNAME=kaiten-mcp.example.com

# Allowed CORS origin (default: https://claude.ai)
# CORS_ORIGIN=https://claude.ai

# ---- Server ----
PORT=3000

# ---- DANGER: local development only ----
# Set to 1 to skip ALL authentication. Never set in production.
# ALLOW_UNAUTHENTICATED=1
